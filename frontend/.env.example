# Базовый URL API пустой = те же origin + proxy Vite (`/api` → бэкенд)
VITE_API_BASE=

# Цель прокси (vite.config proxy /api), по умолчанию 127.0.0.1:3000
# VITE_PROXY_TARGET=http://127.0.0.1:3000

# Bearer без Telegram (вставляется автоматически при старте)
# VITE_DEV_JWT=

# PostHog (опционально)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
