# БД (docker-compose из корня репо)
DATABASE_URL=postgresql://egepro:egepro@127.0.0.1:5432/egepro?schema=public

# Redis (Bull + кэш)
REDIS_URL=redis://127.0.0.1:6379

# HTTP
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
APP_PUBLIC_URL=http://127.0.0.1:3000

# Auth (обязательно для POST /api/auth/telegram и Bearer)
JWT_SECRET=замените-на-длинную-случайную-строку
JWT_EXPIRES_DAYS=14

# Telegram Bot (валидация initData)
TELEGRAM_BOT_TOKEN=

# CORS (через запятую; для Vite dev + Telegram + прод-фронт на Vercel)
# CORS_ORIGINS=http://localhost:5173,...,https://<project>.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://web.telegram.org

# S3 (опционально; без ключа — файлы в ./uploads)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1
# AWS_S3_BUCKET=
# AWS_S3_PUBLIC_BASE=https://…

# Yandex Foundation Models
# YANDEX_FOLDER_ID=
# YANDEX_API_KEY=
# YANDEX_MODEL_URI=

# Внутр. вызов POST /api/coins/earn
# INTERNAL_COIN_EARN_KEY=

# Отключить воркер Bull (только inline fallback)
# DISABLE_BULL=0
